{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["dom", "dom.iterable", "esnext"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"paths": {
			"@": ["./src/index.ts"],
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*.ts", "scripts/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
