{
  "kind": "filter",
  "name": "round",
  "docsUrl": "https://shopify.dev/docs/api/liquid/filters/round",
  "renderedExamples": [
    {
      "code": "{{ 2.7 | round }}\n{{ 1.3 | round }}",
      "output": "3\n1"
    },
    {
      "code": "{{ 3.14159 | round: 2 }}",
