{
	"name": "@augeo/assay",
	"version": "0.1.0",
	"description": "A minimal, TypeScript-first testing stack for Shopify Liquid Themes.",
	"author": "Sean Healy",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/seanhealy/assay.git"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./preset": {
			"types": "./dist/preset.d.ts",
			"import": "./dist/preset.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"lint": "biome check && prettier --check .",
		"lint:fix": "biome check --write && prettier --write .",
		"typecheck": "tsc --noEmit",
		"verify": "npm run lint:fix && npm run typecheck",
		"test": "npm test --prefix example",
		"docs:update": "git submodule update --remote vendor/theme-liquid-docs",
		"docs:audit": "tsx scripts/audit-shopify-compat.ts",
		"prepublishOnly": "npm run build"
	},
	"volta": {
		"node": "24.10.0",
		"npm": "11.6.2"
	},
	"peerDependencies": {
		"@vitest/browser-playwright": ">=4.0.0",
		"vitest": ">=4.0.0"
	},
	"dependencies": {
		"liquidjs": "^10.25.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^25.5.2",
		"@vitest/browser-playwright": "^4.1.2",
		"prettier": "^3.8.1",
		"tsdown": "^0.21.7",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
